<Window x:Class="WinOptimizer.AI.PromptEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Prompt"
        Height="560" Width="860"
        MinHeight="420" MinWidth="620"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptEditorTitleText" Text="Edit Prompt Before Sending" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <TextBox x:Name="PromptEditorTextBox"
                 Grid.Row="1"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="13"
                 Padding="10"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnCopyPromptEditor" Content="Copy To Clipboard" Click="BtnCopy_Click" Padding="14,8" Margin="0,0,8,0"/>
            <Button x:Name="BtnClosePromptEditor" Content="Close" Click="BtnClose_Click" Padding="14,8"/>
        </StackPanel>
    </Grid>
</Window>
