<Window x:Class="WinOptimizer.AI.BlacklistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Blacklist" 
        Height="500" Width="600"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">

    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#E81123"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF1435"/>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowBackground" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="#333337"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#262629"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="⛔ Blacklisted Processes" FontSize="22" FontWeight="Bold" 
                       Foreground="{StaticResource TextBrush}"/>
            <TextBlock x:Name="CountText" Text="(0 items)" FontSize="14" 
                       Foreground="{StaticResource SecondaryTextBrush}" Margin="15,0,0,0" VerticalAlignment="Bottom"/>
        </StackPanel>

        <!-- Add Manual -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Process Name:" Foreground="{StaticResource SecondaryTextBrush}" 
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="ManualInputBox" Width="200" VerticalAlignment="Center" 
                     ToolTip="Enter process name (e.g. notepad)"/>
            <CheckBox x:Name="ManualAutoKillChk" Content="Auto-Kill" Foreground="White" 
                      IsChecked="True" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <Button x:Name="BtnAddManual" Content="Add" Margin="10,0,0,0" 
                    Style="{StaticResource SecondaryButtonStyle}" Padding="15,6" FontSize="12"
                    Click="BtnAddManual_Click"/>
        </StackPanel>

        <!-- Blacklist DataGrid -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
            <DataGrid x:Name="BlacklistDataGrid" Style="{StaticResource DataGridStyle}" Margin="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Process Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTemplateColumn Header="Auto-Kill" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding AutoKill, UpdateSourceTrigger=PropertyChanged}" 
                                          Checked="OnAutoKillChanged" Unchecked="OnAutoKillChanged"
                                          HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Added" Binding="{Binding AddedAt, StringFormat=MM/dd/yyyy}" Width="100"/>
                    <DataGridTemplateColumn Header="Actions" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="🗑️" ToolTip="Remove from blacklist" 
                                        Click="BtnRemove_Click" 
                                        Style="{StaticResource SecondaryButtonStyle}" 
                                        Padding="8,4" FontSize="11"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="BtnAddFromRunning" Content="➕ Add Running Process" 
                    Style="{StaticResource ModernButtonStyle}" Padding="15,8" FontSize="13"
                    Click="BtnAddFromRunning_Click" Margin="0,0,20,0"/>
                    
            <Button x:Name="BtnClose" Content="✓ Close" 
                    Style="{StaticResource SecondaryButtonStyle}" Padding="20,8" FontSize="13"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
