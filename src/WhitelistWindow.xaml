<Window x:Class="WinOptimizer.AI.WhitelistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Whitelist" 
        Height="600" Width="700"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">

    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#106EBE"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#E81123"/>
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#FF1435"/>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowBackground" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="#333337"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#262629"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="🛡️ Whitelisted Items" FontSize="22" FontWeight="Bold" 
                       Foreground="{StaticResource TextBrush}"/>
            <TextBlock x:Name="CountText" Text="(0 items)" FontSize="14" 
                       Foreground="{StaticResource SecondaryTextBrush}" Margin="15,0,0,0" VerticalAlignment="Bottom"/>
        </StackPanel>

        <!-- Filters -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Filter by type:" Foreground="{StaticResource SecondaryTextBrush}" 
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox x:Name="TypeFilterComboBox" Width="120" VerticalAlignment="Center" 
                      SelectionChanged="TypeFilterComboBox_SelectionChanged">
                <ComboBoxItem Content="All" IsSelected="True"/>
                <ComboBoxItem Content="Process"/>
                <ComboBoxItem Content="Service"/>
                <ComboBoxItem Content="Task"/>
                <ComboBoxItem Content="Autorun"/>
            </ComboBox>
            <TextBox x:Name="SearchTextBox" Width="200" Margin="15,0,0,0" 
                     VerticalAlignment="Center" TextChanged="SearchTextBox_TextChanged"
                     ToolTip="Search by name or path"/>
            <Button x:Name="BtnClearSearch" Content="✕" Margin="5,0,0,0" 
                    Style="{StaticResource SecondaryButtonStyle}" Padding="8,6" FontSize="10"
                    Click="BtnClearSearch_Click"/>
        </StackPanel>

        <!-- Whitelist DataGrid -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
            <DataGrid x:Name="WhitelistDataGrid" Style="{StaticResource DataGridStyle}" Margin="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150"/>
                    <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Added" Binding="{Binding AddedAt, StringFormat=MM/dd/yyyy}" Width="90"/>
                    <DataGridTemplateColumn Header="Actions" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="📂" ToolTip="Open Folder" 
                                            Click="BtnOpenFolder_Click" 
                                            Style="{StaticResource SecondaryButtonStyle}" 
                                            Padding="8,4" FontSize="11" Margin="0,0,6,0"/>
                                    <Button Content="🗑️" ToolTip="Remove from whitelist" 
                                            Click="BtnRemove_Click" 
                                            Style="{StaticResource DangerButtonStyle}" 
                                            Padding="8,4" FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="BtnAddProcess" Content="➕ Add Running Process" 
                    Style="{StaticResource ModernButtonStyle}" Padding="15,8" FontSize="13"
                    Click="BtnAddProcess_Click" Margin="0,0,20,0" Background="#28a745"/>
                    
            <Button x:Name="BtnExport" Content="📤 Export" 
                    Style="{StaticResource SecondaryButtonStyle}" Padding="15,8" FontSize="13"
                    Click="BtnExport_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnClearAll" Content="🗑️ Clear All" 
                    Style="{StaticResource DangerButtonStyle}" Padding="15,8" FontSize="13"
                    Click="BtnClearAll_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnClose" Content="✓ Close" 
                    Style="{StaticResource ModernButtonStyle}" Padding="20,8" FontSize="13"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
