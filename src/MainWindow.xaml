<Window x:Class="WinOptimizer.AI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="WinOptimizer.AI" 
        Icon="assets/ico/WinOptimizer.ico"
        Height="900" Width="1300"
        MinHeight="700" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#121212"
        Foreground="White">

    <Window.Resources>
        <!-- COLORS & BRUSHES -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#121212"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#333333"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#AAAAAA"/>
        
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#007ACC" Offset="0"/>
            <GradientStop Color="#005A9E" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#28A745" Offset="0"/>
            <GradientStop Color="#1E7E34" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="DangerGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#DC3545" Offset="0"/>
            <GradientStop Color="#BD2130" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/> <!-- Fallback -->
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#009BE0"/>
        
        <!-- EFFECTS -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="4" Direction="270" Color="Black" Opacity="0.3"/>
        <DropShadowEffect x:Key="ButtonShadow" BlurRadius="8" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.2"/>

        <!-- STYLES -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          Grid.Column="2" 
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" 
                                                Background="#2D2D2D" 
                                                BorderBrush="#333333" 
                                                BorderThickness="1" 
                                                CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="Arrow" 
                                                      Grid.Column="1" 
                                                      Fill="White" 
                                                      HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center" 
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="Border" Property="Background" Value="#3D3D3D" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite"
                                              IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,0,23,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                            <Popup Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" 
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid Name="DropDown"
                                      SnapsToDevicePixels="True"                
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#2D2D2D"
                                            BorderThickness="1"
                                            BorderBrush="#333333"
                                            CornerRadius="0,0,6,6"/>
                                    <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0,0,0,0" CornerRadius="6" Margin="5,2">
                            <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252525"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" CenterX="0.5" CenterY="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{x:Null}"/>
        </Style>

        <!-- DataGrid Style -->
        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#333333"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowBackground" Value="#1E1E1E"/>
            <Setter Property="AlternatingRowBackground" Value="#252525"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="ColumnHeaderHeight" Value="40"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,20,20"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#181818" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo Area -->
                <StackPanel Grid.Row="0" Margin="20,30,20,40" Orientation="Horizontal">
                    <Image Source="assets/ico/WinOptimizer.png" Width="42" Height="42" Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="WINOPTIMIZER" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="AI EDITION" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1">
                    <Button x:Name="NavDashboard" Content="📊  Dashboard" Style="{StaticResource SidebarButtonStyle}" Click="NavButton_Click" Tag="0"/>
                    <Button x:Name="NavProcesses" Content="⚡  Processes" Style="{StaticResource SidebarButtonStyle}" Click="NavButton_Click" Tag="1"/>
                    <Button x:Name="NavGameMode" Content="🎮  Game Mode" Style="{StaticResource SidebarButtonStyle}" Click="NavButton_Click" Tag="2"/>
                    <Button x:Name="NavServices" Content="⚙️  Services" Style="{StaticResource SidebarButtonStyle}" Click="NavButton_Click" Tag="3"/>
                    <Button x:Name="NavTasks" Content="📅  Tasks" Style="{StaticResource SidebarButtonStyle}" Click="NavButton_Click" Tag="4"/>
                    <Button x:Name="NavAutoruns" Content="🚀  Autoruns" Style="{StaticResource SidebarButtonStyle}" Click="NavButton_Click" Tag="5"/>
                    <Button x:Name="NavSettings" Content="⚙️  Settings" Style="{StaticResource SidebarButtonStyle}" Click="NavButton_Click" Tag="6"/>
                    <Button x:Name="NavOtherApps" Content="🛠️  Other Apps" Style="{StaticResource SidebarButtonStyle}" Click="NavButton_Click" Tag="7"/>
                </StackPanel>

                <!-- Bottom Status -->
                <StackPanel Grid.Row="2" Margin="15,20">
                    <Border x:Name="StatusPanel" Background="#252525" CornerRadius="6" Padding="12">
                        <StackPanel>
                            <TextBlock Text="STATUS" FontSize="10" Foreground="#666" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock x:Name="GpuStatusIcon" Text="⚪" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="GpuStatusText" Text="Ready" FontSize="12" Foreground="#CCCCCC" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="HeaderSubtitle" Text="v1.0.0" FontSize="10" Foreground="#555" Margin="0,5,0,0" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0" HorizontalAlignment="Center">
                        <ComboBox x:Name="LanguageComboBox" Width="140" SelectionChanged="LanguageComboBox_SelectionChanged" FontSize="12" Padding="5,4">
                            <ComboBoxItem Content="English" IsSelected="True"/>
                            <ComboBoxItem Content="Français"/>
                            <ComboBoxItem Content="Español"/>
                            <ComboBoxItem Content="Deutsch"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Credits -->
                    <TextBlock HorizontalAlignment="Center" Margin="0,15,0,0" FontSize="11" Foreground="#666">
                        <Run Text="Made by "/>
                        <Hyperlink NavigateUri="https://github.com/Walkoud/WinOptimizer.AI" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{StaticResource AccentBrush}" TextDecorations="None">
                            <Run Text="Walkoud"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Top Bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Grid Grid.Row="0" Margin="30,30,30,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="PageTitle" Text="Dashboard" FontSize="24" FontWeight="Bold" Foreground="White"/>
                
                <!-- Global Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnProcessSettings" Content="⚙️" ToolTip="Settings" Style="{StaticResource SecondaryButtonStyle}" Padding="10" Click="BtnProcessSettings_Click"/>
                    <Button x:Name="BtnProcessHelp" Content="❓" ToolTip="Help" Style="{StaticResource SecondaryButtonStyle}" Padding="10" Margin="10,0,0,0" Click="BtnProcessHelp_Click"/>
                </StackPanel>
            </Grid>

            <!-- Tabs (Hidden Headers) -->
            <TabControl x:Name="MainTabControl" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="20,0,20,20">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.ItemContainerStyle>

                <!-- TAB 0: DASHBOARD -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Hero Cards -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Monitoring Card -->
                            <Border Style="{StaticResource CardStyle}" Grid.Column="0">
                                <StackPanel>
                                    <TextBlock Text="SYSTEM MONITORING" FontSize="12" Foreground="#888" FontWeight="Bold"/>
                                    <TextBlock Text="AI-Powered Optimization" FontSize="18" FontWeight="SemiBold" Margin="0,5,0,15"/>
                                    
                                    <Button x:Name="BtnToggleMonitoring" Content="▶️ START MONITORING" Style="{StaticResource ModernButtonStyle}" Width="200" Click="BtnToggleMonitoring_Click" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <!-- Game Mode Card -->
                            <Border x:Name="GameModePanel" Style="{StaticResource CardStyle}" Grid.Column="1" Background="#1A2633" BorderBrush="#2A4055">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="GAME MODE" FontSize="12" Foreground="#007ACC" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="GameModeStatusText" Text="Inactive" FontSize="12" Foreground="#666" HorizontalAlignment="Right" FontStyle="Italic"/>
                                    </Grid>
                                    
                                    <TextBlock Text="Optimize performance for gaming." Foreground="#AAA" Margin="0,5,0,15"/>
                                    
                                    <Button x:Name="BtnGoToGameMode" Content="GO TO GAME MODE" Style="{StaticResource ModernButtonStyle}" Background="#007ACC" Width="200" Click="BtnGoToGameMode_Click" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Stats / Recent Activity -->
                        <Border Style="{StaticResource CardStyle}" Grid.Row="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="RECENT ACTIVITY" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Button x:Name="BtnClearHistory" Content="Clear" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" FontSize="11" Margin="15,0,0,0" Click="BtnClearHistory_Click"/>
                                    <Button x:Name="BtnExportHistory" Content="Export" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" FontSize="11" Margin="5,0,0,0" Click="BtnExportHistory_Click"/>
                                </StackPanel>

                                <DataGrid x:Name="GpuHistoryDataGrid" Grid.Row="1" Style="{StaticResource DataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding TimeAgo}" Width="80"/>
                                        <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="150"/>
                                        <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="100"/>
                                        <DataGridTextColumn Header="GPU Impact" Binding="{Binding GpuUsage, StringFormat={}{0:F1}%}" Width="90"/>
                                        <DataGridTemplateColumn Header="Quick Actions" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="Whitelist" Click="BtnHistoryWhitelist_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="8,2" FontSize="10" Margin="0,0,5,0"/>
                                                        <Button Content="Kill" Click="BtnHistoryKill_Click" Style="{StaticResource ModernButtonStyle}" Background="#DC3545" Padding="8,2" FontSize="10"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                
                                <Border x:Name="GpuHistoryPanel" Visibility="Collapsed"/> <!-- Legacy hidden placeholder -->
                            </Grid>
                        </Border>

                        <!-- Logs (Expander) -->
                        <Expander Grid.Row="2" Header="Activity Log" Foreground="#888" Margin="0,10,0,0">
                            <Border Background="#111" CornerRadius="4" Padding="10" Height="150">
                                <ScrollViewer>
                                    <TextBlock x:Name="DashboardLogTextBlock" Foreground="#AAA" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Border>
                        </Expander>
                    </Grid>
                </TabItem>

                <!-- TAB 1: PROCESSES -->
                <TabItem x:Name="TabProcesses">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Filters/Controls -->
                        <Border Grid.Row="0" Margin="0,0,0,15" Background="#1E1E1E" CornerRadius="6" Padding="10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="PROCESS MANAGEMENT" FontWeight="Bold" Foreground="#888" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                <Button x:Name="BtnViewWhitelist" Content="🛡️ Manage Whitelist" Style="{StaticResource SecondaryButtonStyle}" Click="BtnViewWhitelist_Click" Margin="0,0,10,0"/>
                                <Button x:Name="BtnViewHistory" Content="📜 View History" Style="{StaticResource SecondaryButtonStyle}" Click="BtnViewHistory_Click"/>
                                <TextBlock Text="(Configure Auto-Kill and Alerts in Settings)" FontSize="11" Foreground="#666" VerticalAlignment="Center" Margin="20,0,0,0" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>

                        <!-- Top 3 Consumers Widget -->
                        <Border Style="{StaticResource CardStyle}" Grid.Row="1" Margin="0,0,0,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="TOP RESOURCE CONSUMERS" FontSize="12" FontWeight="Bold" Foreground="#888" Margin="0,0,0,15"/>
                                
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- CPU -->
                                    <Border Grid.Column="0" Background="#252525" CornerRadius="8" Margin="0,0,10,0" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="CPU" Foreground="#888" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock x:Name="TopCpuName" Text="-" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock x:Name="TopCpuValue" Text="0%" Foreground="{StaticResource AccentGradient}" FontSize="20" FontWeight="Bold" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- GPU -->
                                    <Border Grid.Column="1" Background="#252525" CornerRadius="8" Margin="0,0,10,0" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="GPU" Foreground="#888" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock x:Name="TopGpuName" Text="-" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock x:Name="TopGpuValue" Text="0%" Foreground="{StaticResource DangerGradient}" FontSize="20" FontWeight="Bold" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- RAM -->
                                    <Border Grid.Column="2" Background="#252525" CornerRadius="8" Margin="0,0,10,0" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="RAM" Foreground="#888" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock x:Name="TopRamName" Text="-" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock x:Name="TopRamValue" Text="0 MB" Foreground="{StaticResource SuccessGradient}" FontSize="20" FontWeight="Bold" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Network -->
                                    <Border Grid.Column="3" Background="#252525" CornerRadius="8" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="NETWORK" Foreground="#888" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock x:Name="TopNetName" Text="-" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock x:Name="TopNetValue" Text="0 MB/s" Foreground="#007ACC" FontSize="20" FontWeight="Bold" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Process Lists -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.8*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Active Processes -->
                            <Border Style="{StaticResource CardStyle}" Grid.Column="0" Margin="0,0,10,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="ACTIVE PROCESSES" FontSize="12" FontWeight="Bold" Foreground="#888" Margin="0,0,0,10"/>
                                    <DataGrid x:Name="ProcessDataGrid" Grid.Row="1" Style="{StaticResource DataGridStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="150"/>
                                            <DataGridTextColumn Header="CPU %" Binding="{Binding CpuUsage}" Width="60"/>
                                            <DataGridTextColumn Header="GPU %" Binding="{Binding GpuUsage}" Width="60"/>
                                            <DataGridTextColumn Header="RAM" Binding="{Binding RamUsageMB}" Width="70"/>
                                            <DataGridTextColumn Header="Net MB/s" Binding="{Binding NetworkUsageMB}" Width="70"/>
                                            <DataGridTemplateColumn Header="Actions" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4">
                                                            <Button Content="🛡️" ToolTip="Whitelist" Click="BtnWhitelistProcess_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="5,2" FontSize="12" Margin="0,0,5,0" Width="30"/>
                                                            <Button Content="⛔" ToolTip="Blacklist" Click="BtnBlacklistProcess_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="5,2" FontSize="12" Margin="0,0,5,0" Width="30"/>
                                                            <Button Content="🎮" ToolTip="Designate as Game" Click="BtnDesignateAsGame_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="5,2" FontSize="12" Width="30"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <!-- Recommendations -->
                            <Border Style="{StaticResource CardStyle}" Grid.Column="1" Margin="10,0,0,0" BorderBrush="#007ACC">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="AI RECOMMENDATIONS" FontSize="12" FontWeight="Bold" Foreground="#007ACC"/>
                                        <Border x:Name="PerformanceBanner" Background="#FFB900" CornerRadius="4" Padding="6,2" Margin="10,-2,0,0" Visibility="Collapsed">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="PerformanceBannerText" Text="High Load" FontSize="10" Foreground="Black" FontWeight="Bold"/>
                                                <Button x:Name="BtnDismissBanner" Content="✕" Click="BtnDismissBanner_Click" Background="Transparent" BorderThickness="0" Padding="0" Margin="5,0,0,0" Foreground="Black" FontSize="10"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    
                                    <DataGrid x:Name="ProcessRecsDataGrid" Grid.Row="1" Style="{StaticResource DataGridStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Target" Binding="{Binding Name}" Width="*"/>
                                            <DataGridTextColumn Header="Reason" Binding="{Binding AiReason}" Width="80"/>
                                            <DataGridTemplateColumn Header="Actions" Width="Auto">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="💀" ToolTip="Kill" Click="BtnApplyProcessRec_Click" Style="{StaticResource ModernButtonStyle}" Background="#DC3545" Padding="5,2" FontSize="12" Margin="0,0,5,0" Width="30"/>
                                                            <Button Content="🛡️" ToolTip="Ignore/Whitelist" Click="BtnRecWhitelist_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="5,2" FontSize="12" Width="30"/>
                                                            <Button Content="📂" ToolTip="Open Folder" Click="BtnRecFolder_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="5,2" FontSize="12" Margin="5,0,0,0" Width="30"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- TAB 2: GAME MODE (Extended) -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardStyle}" Grid.Row="0">
                            <StackPanel>
                                <TextBlock Text="GAME MODE SETTINGS" FontSize="12" FontWeight="Bold" Foreground="#888" Margin="0,0,0,10"/>
                                <TextBlock Text="Game Mode automatically detects when you are playing and optimizes system resources." Foreground="#AAA" TextWrapping="Wrap" Margin="0,0,0,15"/>
                                
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="BtnTabToggleGameMode" Content="START GAME MODE" Style="{StaticResource ModernButtonStyle}" Background="#28A745" Width="180" Click="BtnToggleGameMode_Click" Margin="0,0,10,0"/>
                                    <Button x:Name="BtnRestoreClosedApps" Content="↩️ Restore Apps" Style="{StaticResource SecondaryButtonStyle}" Click="BtnRestoreClosedApps_Click" Margin="0,0,10,0" ToolTip="Restore processes killed by Game Mode"/>
                                    <Button x:Name="BtnManageWhitelist" Content="🛡️ WHITELIST" Style="{StaticResource SecondaryButtonStyle}" Click="BtnViewWhitelist_Click" Margin="0,0,10,0"/>
                                    <Button x:Name="BtnManageBlacklist" Content="⛔ BLACKLIST" Style="{StaticResource SecondaryButtonStyle}" Click="BtnViewBlacklist_Click" Margin="0,0,10,0"/>
                                    <Button x:Name="BtnAddGameProcess" Content="➕ ADD GAME" Style="{StaticResource SecondaryButtonStyle}" Click="BtnAddGameProcess_Click" ToolTip="Add current running game"/>
                                </StackPanel>
                                
                                <ComboBox x:Name="GameModeComboBox" Margin="0,15,0,5" Width="220" HorizontalAlignment="Left" Padding="10,6" FontSize="12"/>
                                <CheckBox x:Name="AutoKillCheckBox" Content="Auto-kill intruders" Foreground="#CCC" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Grid.Row="1">
                            <StackPanel>
                                <TextBlock Text="SUPPORTED GAMES" FontSize="12" FontWeight="Bold" Foreground="#888" Margin="0,0,0,10"/>
                                <TextBlock Text="Steam, Epic Games, Battle.net, Riot Games" Foreground="White" Margin="0,0,0,5"/>
                                <TextBlock Text="Automatically detects: CS2, Dota 2, Fortnite, Overwatch, Valorant, etc." Foreground="#888" FontSize="11"/>
                                
                                <TextBlock Text="HOW IT WORKS" FontSize="12" FontWeight="Bold" Foreground="#888" Margin="0,20,0,10"/>
                                <TextBlock Text="1. Detects high-GPU usage from non-game processes." Foreground="#AAA" Margin="0,0,0,2"/>
                                <TextBlock Text="2. Checks if the process is in the Whitelist." Foreground="#AAA" Margin="0,0,0,2"/>
                                <TextBlock Text="3. Automatically terminates the process to free up resources (if Auto-Kill is enabled)." Foreground="#AAA" Margin="0,0,0,2"/>
                            </StackPanel>
                        </Border>

                        <!-- Logs (Expander) -->
                        <Expander Grid.Row="2" Header="Activity Log" Foreground="#888" Margin="0,10,0,0">
                            <Border Background="#111" CornerRadius="4" Padding="10" Height="150">
                                <ScrollViewer>
                                    <TextBlock x:Name="GameModeLogTextBlock" Foreground="#AAA" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Border>
                        </Expander>
                    </Grid>
                </TabItem>

                <!-- TAB 3: SERVICES -->
                <TabItem x:Name="TabServices">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardStyle}" Grid.Row="0">
                            <StackPanel>
                                <TextBlock Text="SERVICE OPTIMIZER" FontSize="12" FontWeight="Bold" Foreground="#888" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="BtnScanServices" Content="🔍 SCAN SERVICES" Style="{StaticResource ModernButtonStyle}" Click="BtnScanServices_Click"/>
                                    <Button x:Name="BtnCopyServicePrompt" Content="📋 Copy Prompt" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Click="BtnCopyServicePrompt_Click"/>
                                    <Button x:Name="BtnPasteServiceAI" Content="📥 Paste AI Response" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Click="BtnPasteServiceAI_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                    <CheckBox x:Name="ChkNoXbox" Content="I don't use Xbox services" Foreground="White" Margin="0,0,20,0" IsChecked="True"/>
                                    <CheckBox x:Name="ChkNoStore" Content="I don't use Microsoft Store apps" Foreground="White" IsChecked="True"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border x:Name="ServicesSummaryBanner" Grid.Row="1" Background="#2A2A40" BorderBrush="#555" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,20,15" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="AI SUMMARY &amp; RECOMMENDATION" FontSize="12" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,5"/>
                                <TextBlock x:Name="ServicesSummaryText" Text="..." Foreground="#DDD" TextWrapping="Wrap" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Grid.Row="2">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="ServiceActionsPanel">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#252525" CornerRadius="6" Margin="0,0,0,10" Padding="15">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    
                                                    <!-- Header -->
                                                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="14" Foreground="White"/>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding ServiceName}" FontSize="12" Foreground="#888" Margin="0,2,10,5"/>
                                                            <TextBlock Text="{Binding AiReason}" FontSize="12" Foreground="#CCC" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- Current State (Prominent) -->
                                                    <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="CURRENT:" FontSize="11" FontWeight="Bold" Foreground="#888" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#4CAF50" VerticalAlignment="Center">
                                                                <Run Text="{Binding CurrentStartup}"/> <Run Text=" / " Foreground="#555"/> <Run Text="{Binding CurrentState}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Controls (ComboBoxes + Buttons) -->
                                                    <Grid Grid.Row="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <!-- Recommendation Controls -->
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
                                                            <StackPanel Margin="0,0,15,0">
                                                                <TextBlock Text="Recommended Startup" FontSize="10" Foreground="#888" Margin="0,0,0,2"/>
                                                                <ComboBox SelectedValue="{Binding UserSelectedStartup, Mode=TwoWay}" Width="120" Padding="5">
                                                                     <sys:String>Automatic</sys:String>
                                                                     <sys:String>Manual</sys:String>
                                                                     <sys:String>Disabled</sys:String>
                                                                     <sys:String>Delayed</sys:String>
                                                                </ComboBox>
                                                            </StackPanel>
                                                            
                                                            <StackPanel>
                                                                <TextBlock Text="Recommended State" FontSize="10" Foreground="#888" Margin="0,0,0,2"/>
                                                                <ComboBox SelectedValue="{Binding UserSelectedState, Mode=TwoWay}" Width="110" Padding="5">
                                                                     <sys:String>Running</sys:String>
                                                                     <sys:String>Stopped</sys:String>
                                                                     <sys:String>Paused</sys:String>
                                                                </ComboBox>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <!-- Actions -->
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                                            <Button Content="APPLY" Tag="{Binding}" Click="BtnApplyServiceWithSelection_Click" Style="{StaticResource ModernButtonStyle}" Background="#007ACC" Padding="15,6" FontSize="12" Margin="0,0,10,0" Height="30"/>
                                                            <Button Content="🛡️" ToolTip="Whitelist" Tag="{Binding}" Click="BtnWhitelistService_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="8,5" FontSize="14" Height="30" Width="35"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 4: TASKS -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource CardStyle}" Grid.Row="0">
                            <StackPanel>
                                <TextBlock Text="SCHEDULED TASKS" FontSize="12" FontWeight="Bold" Foreground="#888" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="BtnScanTasks" Content="🔍 SCAN TASKS" Style="{StaticResource ModernButtonStyle}" Click="BtnScanTasks_Click"/>
                                    <Button x:Name="BtnCopyTaskPrompt" Content="📋 Copy Prompt" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Click="BtnCopyTaskPrompt_Click"/>
                                    <Button x:Name="BtnPasteTaskAI" Content="📥 Paste AI Response" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Click="BtnPasteTaskAI_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border x:Name="TasksSummaryBanner" Grid.Row="1" Background="#2A2A40" BorderBrush="#555" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,20,15" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="AI SUMMARY &amp; RECOMMENDATION" FontSize="12" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TasksSummaryText" Text="..." Foreground="#DDD" TextWrapping="Wrap" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Grid.Row="2">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="TaskActionsPanel">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#252525" CornerRadius="4" Margin="0,0,0,8" Padding="12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding TaskName}" FontWeight="Bold" Foreground="White"/>
                                                        <TextBlock Text="{Binding AiReason}" FontSize="11" Foreground="#AAA" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <Button Content="Properties" Click="BtnTaskProperties_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="10,4" FontSize="11" Margin="0,0,5,0"/>
                                                        <Button Content="Disable" Click="BtnApplyTask_Click" Style="{StaticResource ModernButtonStyle}" Padding="10,4" FontSize="11" Margin="0,0,5,0"/>
                                                        <Button Content="Whitelist" Click="BtnWhitelistTask_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="10,4" FontSize="11"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 5: AUTORUNS -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource CardStyle}" Grid.Row="0">
                            <StackPanel>
                                <TextBlock Text="STARTUP APPS (AUTORUNS)" FontSize="12" FontWeight="Bold" Foreground="#888" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="BtnScanAutoruns" Content="🔍 SCAN STARTUP" Style="{StaticResource ModernButtonStyle}" Click="BtnScanAutoruns_Click"/>
                                    <Button x:Name="BtnBrowseAutorunFolder" Content="📂 Browse Folder" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Click="BtnBrowseAutorunFolder_Click"/>
                                    <Button x:Name="BtnCopyAutorunPrompt" Content="📋 Copy Prompt" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Click="BtnCopyAutorunPrompt_Click"/>
                                    <Button x:Name="BtnPasteAutorunAI" Content="📥 Paste AI Response" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Click="BtnPasteAutorunAI_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border x:Name="AutorunsSummaryBanner" Grid.Row="1" Background="#2A2A40" BorderBrush="#555" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,20,15" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="AI SUMMARY &amp; RECOMMENDATION" FontSize="12" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,5"/>
                                <TextBlock x:Name="AutorunsSummaryText" Text="..." Foreground="#DDD" TextWrapping="Wrap" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Grid.Row="2">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="AutorunActionsPanel">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#252525" CornerRadius="4" Margin="0,0,0,8" Padding="12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Image Source="{Binding Icon}" Width="24" Height="24" Margin="0,0,15,0"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding EntryName}" FontWeight="Bold" Foreground="White"/>
                                                        <TextBlock Text="{Binding Company}" FontSize="11" Foreground="#888"/>
                                                        <TextBlock Text="{Binding AiReason}" FontSize="11" Foreground="#AAA" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                        <Button Content="Disable" Click="BtnApplyAutorun_Click" Style="{StaticResource ModernButtonStyle}" Padding="10,4" FontSize="11"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 6: SETTINGS -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,20,20">
                                <!-- General Settings -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="LblLanguage" Text="Language / Langue :" VerticalAlignment="Center" Foreground="#AAA" Width="140"/>
                                        <ComboBox x:Name="LanguageComboBoxSettings" Width="200" SelectionChanged="LanguageComboBox_SelectionChanged">
                                            <ComboBoxItem Content="English" Tag="English"/>
                                            <ComboBoxItem Content="Français" Tag="Français"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <!-- Global Monitoring -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="GLOBAL MONITORING" FontSize="12" FontWeight="Bold" Foreground="#888" Margin="0,0,0,10"/>
                                        <Button x:Name="BtnToggleMonitoringSettings" Content="▶️ START MONITORING" Style="{StaticResource ModernButtonStyle}" Width="200" Click="BtnToggleMonitoring_Click" HorizontalAlignment="Left"/>
                                        
                                        <Expander Header="Advanced Settings" Foreground="#AAA" Margin="0,15,0,0">
                                            <StackPanel Margin="0,10,0,0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                     <TextBlock Text="Check Interval (sec):" Foreground="#AAA" VerticalAlignment="Center" Width="140"/>
                                                     <TextBox x:Name="IntervalInputSettings" Text="2" Width="50" Padding="4" TextAlignment="Center"/>
                                                     <TextBlock Text="How often to scan processes" Foreground="#666" VerticalAlignment="Center" Margin="10,0,0,0" FontStyle="Italic" FontSize="11"/>
                                                </StackPanel>
                                                
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                     <TextBlock Text="Alert Duration (sec):" Foreground="#AAA" VerticalAlignment="Center" Width="140"/>
                                                     <TextBox x:Name="DurationSecondsInput" Text="30" Width="50" Padding="4" TextAlignment="Center"/>
                                                     <TextBlock Text="Time before triggering alert/kill" Foreground="#666" VerticalAlignment="Center" Margin="10,0,0,0" FontStyle="Italic" FontSize="11"/>
                                                </StackPanel>
                                                
                                                <CheckBox x:Name="DevModeCheckBoxSettings" Content="Developer Mode (Show verbose logs &amp; simulate GPU)" Foreground="#666" Margin="0,5,0,0"/>
                                                <CheckBox x:Name="ChkLowImpactMode" Content="Mode faible impact CPU (Recommandé)" Foreground="#666" Margin="0,5,0,0"/>
                                            </StackPanel>
                                        </Expander>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="RESOURCE CONFIGURATION" FontSize="14" FontWeight="Bold" Foreground="#888" Margin="0,10,0,15"/>

                                <!-- GPU Settings -->
                                <Border Style="{StaticResource CardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="GPU" FontSize="20" FontWeight="Bold" Foreground="#888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        
                                        <StackPanel Grid.Column="1">
                                            <CheckBox x:Name="ChkMonitorGpu" Content="Enable GPU Monitoring" IsChecked="True" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <StackPanel Orientation="Horizontal" Margin="20,0,0,10">
                                                <TextBlock Text="Threshold:" Width="100" Foreground="#AAA" VerticalAlignment="Center"/>
                                                <TextBox x:Name="GpuThresholdInput" Text="5" Width="60" Padding="4" TextAlignment="Center"/>
                                                <TextBlock Text="%" Foreground="#AAA" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                                <TextBlock Text="Actions:" Width="100" Foreground="#AAA" VerticalAlignment="Center"/>
                                                <CheckBox x:Name="ChkNotifyGpu" Content="Notify Only" IsChecked="True" Foreground="White" Margin="0,0,15,0"/>
                                                <CheckBox x:Name="ChkKillGpuGame" Content="Auto-Kill (Game Mode)" Foreground="#FFB900" Margin="0,0,15,0"/>
                                                <CheckBox x:Name="ChkKillGpuGlobal" Content="Auto-Kill (Always)" Foreground="#DC3545"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- CPU Settings -->
                                <Border Style="{StaticResource CardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="CPU" FontSize="20" FontWeight="Bold" Foreground="#888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        
                                        <StackPanel Grid.Column="1">
                                            <CheckBox x:Name="ChkMonitorCpu" Content="Enable CPU Monitoring" IsChecked="True" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <StackPanel Orientation="Horizontal" Margin="20,0,0,10">
                                                <TextBlock Text="Threshold:" Width="100" Foreground="#AAA" VerticalAlignment="Center"/>
                                                <TextBox x:Name="CpuThresholdInput" Text="50" Width="60" Padding="4" TextAlignment="Center"/>
                                                <TextBlock Text="%" Foreground="#AAA" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                                <TextBlock Text="Actions:" Width="100" Foreground="#AAA" VerticalAlignment="Center"/>
                                                <CheckBox x:Name="ChkNotifyCpu" Content="Notify Only" IsChecked="True" Foreground="White" Margin="0,0,15,0"/>
                                                <CheckBox x:Name="ChkKillCpuGame" Content="Auto-Kill (Game Mode)" Foreground="#FFB900" Margin="0,0,15,0"/>
                                                <CheckBox x:Name="ChkKillCpuGlobal" Content="Auto-Kill (Always)" Foreground="#DC3545"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- RAM Settings -->
                                <Border Style="{StaticResource CardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="RAM" FontSize="20" FontWeight="Bold" Foreground="#888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        
                                        <StackPanel Grid.Column="1">
                                            <CheckBox x:Name="ChkMonitorRam" Content="Enable RAM Monitoring" IsChecked="True" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <StackPanel Orientation="Horizontal" Margin="20,0,0,10">
                                                <TextBlock Text="Threshold:" Width="100" Foreground="#AAA" VerticalAlignment="Center"/>
                                                <TextBox x:Name="RamThresholdInput" Text="2048" Width="60" Padding="4" TextAlignment="Center"/>
                                                <TextBlock Text="MB" Foreground="#AAA" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                                <TextBlock Text="Actions:" Width="100" Foreground="#AAA" VerticalAlignment="Center"/>
                                                <CheckBox x:Name="ChkNotifyRam" Content="Notify Only" IsChecked="True" Foreground="White" Margin="0,0,15,0"/>
                                                <CheckBox x:Name="ChkKillRamGame" Content="Auto-Kill (Game Mode)" Foreground="#FFB900" Margin="0,0,15,0"/>
                                                <CheckBox x:Name="ChkKillRamGlobal" Content="Auto-Kill (Always)" Foreground="#DC3545"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Network Settings -->
                                <Border Style="{StaticResource CardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="NET" FontSize="20" FontWeight="Bold" Foreground="#888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        
                                        <StackPanel Grid.Column="1">
                                            <CheckBox x:Name="ChkMonitorNet" Content="Enable Network Monitoring" IsChecked="True" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <StackPanel Orientation="Horizontal" Margin="20,0,0,10">
                                                <TextBlock Text="Threshold:" Width="100" Foreground="#AAA" VerticalAlignment="Center"/>
                                                <TextBox x:Name="NetThresholdInput" Text="10" Width="60" Padding="4" TextAlignment="Center"/>
                                                <ComboBox x:Name="ComboNetUnit" Width="70" Margin="5,0,0,0" SelectedIndex="0">
                                                    <ComboBoxItem Content="MB/s"/>
                                                    <ComboBoxItem Content="Mb/s"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                                <TextBlock Text="Actions:" Width="100" Foreground="#AAA" VerticalAlignment="Center"/>
                                                <CheckBox x:Name="ChkNotifyNet" Content="Notify Only" IsChecked="True" Foreground="White" Margin="0,0,15,0"/>
                                                <CheckBox x:Name="ChkKillNetGame" Content="Auto-Kill (Game Mode)" Foreground="#FFB900" Margin="0,0,15,0"/>
                                                <CheckBox x:Name="ChkKillNetGlobal" Content="Auto-Kill (Always)" Foreground="#DC3545"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <!-- TAB 7: OTHER APPS -->
                <TabItem>
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="OPTIMIZATION TOOLS" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>
                        
                        <ScrollViewer Grid.Row="1">
                            <WrapPanel>
                                <!-- Chris Titus -->
                                <Border Style="{StaticResource CardStyle}" Width="350" Height="220" Margin="0,0,20,20">
                                    <StackPanel>
                                        <TextBlock Text="Chris Titus Tech's WinUtil" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                                        <TextBlock Text="Comprehensive Windows utility for debloating, installing programs, and tweaks." Foreground="#AAA" TextWrapping="Wrap" Height="60"/>
                                        
                                        <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                            <Button Content="🚀 Run Tool" Click="BtnRunChrisTitus_Click" Style="{StaticResource ModernButtonStyle}" Width="140" Margin="0,0,10,0" Padding="10"/>
                                            <Button Content="🌐 Website" Click="BtnWebChrisTitus_Click" Style="{StaticResource SecondaryButtonStyle}" Width="140" Padding="10"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Win11Debloat -->
                                <Border Style="{StaticResource CardStyle}" Width="350" Height="220" Margin="0,0,20,20">
                                    <StackPanel>
                                        <TextBlock Text="Win11Debloat" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                                        <TextBlock Text="Simple, lightweight PowerShell script to remove bloatware from Windows 11." Foreground="#AAA" TextWrapping="Wrap" Height="60"/>
                                        
                                        <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                            <Button Content="🚀 Run Tool" Click="BtnRunWin11Debloat_Click" Style="{StaticResource ModernButtonStyle}" Width="140" Margin="0,0,10,0" Padding="10"/>
                                            <Button Content="🌐 Website" Click="BtnWebWin11Debloat_Click" Style="{StaticResource SecondaryButtonStyle}" Width="140" Padding="10"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- DebloaterTool -->
                                <Border Style="{StaticResource CardStyle}" Width="350" Height="220" Margin="0,0,20,20">
                                    <StackPanel>
                                        <TextBlock Text="DebloaterTool" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                                        <TextBlock Text="Advanced debloater with GUI to customize your Windows experience." Foreground="#AAA" TextWrapping="Wrap" Height="60"/>
                                        
                                        <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                            <Button Content="🚀 Run Tool" Click="BtnRunDebloaterTool_Click" Style="{StaticResource ModernButtonStyle}" Width="140" Margin="0,0,10,0" Padding="10"/>
                                            <Button Content="🌐 Website" Click="BtnWebDebloaterTool_Click" Style="{StaticResource SecondaryButtonStyle}" Width="140" Padding="10"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</Window>