<Window x:Class="WinOptimizer.AI.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Action History" 
        Height="650" Width="800"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">

    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#E81123"/>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowBackground" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="#333337"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#262629"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="📜 Action History" FontSize="22" FontWeight="Bold" 
                       Foreground="{StaticResource TextBrush}"/>
            <TextBlock x:Name="CountText" Text="(0 actions)" FontSize="14" 
                       Foreground="{StaticResource SecondaryTextBrush}" Margin="15,0,0,0" VerticalAlignment="Bottom"/>
        </StackPanel>

        <!-- Stats Summary -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="AutoKillCount" Text="🤖 AutoKills: 0" Foreground="{StaticResource TextBrush}" Margin="0,0,20,0"/>
                <TextBlock x:Name="ManualKillCount" Text="🔴 Manual Kills: 0" Foreground="{StaticResource TextBrush}" Margin="0,0,20,0"/>
                <TextBlock x:Name="WhitelistCount" Text="🛡️ Whitelists: 0" Foreground="{StaticResource TextBrush}" Margin="0,0,20,0"/>
                <TextBlock x:Name="SnoozeCount" Text="😴 Snoozes: 0" Foreground="{StaticResource TextBrush}"/>
            </StackPanel>
        </Border>

        <!-- Filters -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Filter:" Foreground="{StaticResource SecondaryTextBrush}" 
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox x:Name="TypeFilterComboBox" Width="150" VerticalAlignment="Center" 
                      SelectionChanged="TypeFilterComboBox_SelectionChanged">
                <ComboBoxItem Content="All Actions" IsSelected="True"/>
                <ComboBoxItem Content="🤖 AutoKill"/>
                <ComboBoxItem Content="🔴 Manual Kill"/>
                <ComboBoxItem Content="🛡️ Whitelist"/>
                <ComboBoxItem Content="😴 Snooze"/>
            </ComboBox>
            <TextBox x:Name="SearchTextBox" Width="200" Margin="15,0,0,0" 
                     VerticalAlignment="Center" TextChanged="SearchTextBox_TextChanged"
                     ToolTip="Search by process name or reason"/>
            <Button x:Name="BtnClearSearch" Content="✕" Margin="5,0,0,0" 
                    Style="{StaticResource SecondaryButtonStyle}" Padding="8,6" FontSize="10"
                    Click="BtnClearSearch_Click"/>
        </StackPanel>

        <!-- History DataGrid -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
            <DataGrid x:Name="HistoryDataGrid" Style="{StaticResource DataGridStyle}" Margin="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time" Binding="{Binding TimeAgo}" Width="80"/>
                    <DataGridTextColumn Header="" Binding="{Binding ActionIcon}" Width="30"/>
                    <DataGridTextColumn Header="Action" Binding="{Binding ActionDescription}" Width="250">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Type" Binding="{Binding TargetType}" Width="80"/>
                    <DataGridTextColumn Header="GPU%" Binding="{Binding GpuUsage, StringFormat=F1}" Width="50"/>
                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="ToolTip" Value="{Binding Reason}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Actions" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="📂" ToolTip="Open Folder" 
                                            Click="BtnOpenFolder_Click" 
                                            Style="{StaticResource SecondaryButtonStyle}" 
                                            Padding="8,4" FontSize="11" Margin="0,0,6,0"/>
                                    <Button Content="🛡️" ToolTip="Whitelist" 
                                            Click="BtnWhitelistHistory_Click" 
                                            Style="{StaticResource SecondaryButtonStyle}" 
                                            Padding="8,4" FontSize="11" Margin="0,0,6,0"/>
                                    <Button Content="🔴" ToolTip="Kill Again" 
                                            Click="BtnKillAgain_Click" 
                                            Style="{StaticResource ModernButtonStyle}" 
                                            Padding="8,4" FontSize="11" Margin="0,0,6,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="BtnExport" Content="📤 Export JSON" 
                    Style="{StaticResource SecondaryButtonStyle}" Padding="15,8" FontSize="13"
                    Click="BtnExport_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnClearAll" Content="🗑️ Clear History" 
                    Style="{StaticResource DangerButtonStyle}" Padding="15,8" FontSize="13"
                    Click="BtnClearAll_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnClose" Content="✓ Close" 
                    Style="{StaticResource ModernButtonStyle}" Padding="20,8" FontSize="13"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
